# ==================================================================
# LocateFlow — Production environment template
# Copy to `.env.production` and fill in real values before deploying.
# ==================================================================
#
# Generation helpers:
#   Random 32-byte hex (ADMIN_JWT_SECRET):  openssl rand -hex 32
#   Random 64-hex key (FIELD_ENCRYPTION_KEY): openssl rand -hex 32
#   Random base64url secret (CRON_SECRET):  openssl rand -base64 36
#
# ── Required: MySQL ────────────────────────────────────────────────
# DigitalOcean Managed MySQL / external DB deployments should set this.
# Example:
#   DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl-mode=REQUIRED
DATABASE_URL=

# Local Docker MySQL deployments use these instead.
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_password_here
MYSQL_DATABASE=locateflow
MYSQL_USER=locateflow
MYSQL_PASSWORD=CHANGE_ME_strong_user_password_here

# ── Required: Domains + Caddy TLS ──────────────────────────────────
WEB_DOMAIN=locateflow.com
ADMIN_DOMAIN=admin.example.com
ERRORS_DOMAIN=errors.example.com   # GlitchTip (error tracking)
IMG_DOMAIN=img.example.com         # imgproxy (signed image transforms)
ACME_EMAIL=ops@example.com

# ── Required: App URLs ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://locateflow.com
# Canonical public origin used by metadata, sitemap, robots, and llms.txt.
# Never use localhost, preview, staging, Vercel preview, or non-HTTPS URLs here.
NEXT_PUBLIC_SITE_URL=https://locateflow.com
SITE_URL=https://locateflow.com
APP_ENV=production

# ── Optional: SEO + Google measurement readiness ───────────────────
# Google Search Console meta verification token. This is rendered as
# <meta name="google-site-verification" ...> when configured.
GOOGLE_SITE_VERIFICATION=
# Prefer GTM for production measurement governance. If GTM is empty and
# GA4 is set, the web app loads direct gtag only after cookie consent.
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Static sitemap lastModified fallback for non-blog pages.
SITE_LAST_MODIFIED=2026-05-01T00:00:00.000Z

# ── Required: Admin auth (min 32 chars) ────────────────────────────
ADMIN_JWT_SECRET=CHANGE_ME_at_least_32_chars_or_openssl_rand_hex_32

# ── Required: User auth (min 32 chars — different from admin!) ─────
USER_JWT_SECRET=CHANGE_ME_at_least_32_chars_or_openssl_rand_hex_32

# ── Required: Admin seed (first login) ─────────────────────────────
# Must contain uppercase, lowercase, digit, special char. Min 16 chars.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=CHANGE_ME_MinSixteen1!

# ── Required: Field encryption (exactly 64 hex chars = 32 bytes) ──
FIELD_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Required: Cron authentication ──────────────────────────────────
# Scheduler (Ofelia / Vercel Cron / external scheduler) uses this to
# hit /api/cron/* endpoints. Generate with: openssl rand -base64 36
CRON_SECRET=CHANGE_ME_openssl_rand_base64_36

# ── Required: Internal webhook secret ──────────────────────────────
# Protects server-to-server internal calls (IP rule cache refresh,
# rate-limit log fan-out, cross-app security events).
# Does not fall back to CRON_SECRET. Generate independently so rotating
# scheduler auth doesn't disrupt internal calls and vice versa.
# Generate with: openssl rand -base64 36
INTERNAL_WEBHOOK_SECRET=CHANGE_ME_openssl_rand_base64_36

# ── Required: Impersonation handoff secret ─────────────────────────
# Gates the admin→web /api/internal/impersonate endpoint. A compromised
# CRON_SECRET must NOT grant the ability to mint impersonation sessions.
# Required for admin impersonation. This does not fall back to CRON_SECRET.
# Generate with: openssl rand -base64 36
IMPERSONATION_HANDOFF_SECRET=CHANGE_ME_openssl_rand_base64_36

# ── OAuth: Google (optional but recommended) ──────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services
# Authorized redirect URI: https://app.example.com/api/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── OAuth: Apple (optional, mandatory for iOS App Store) ──────────
# Set up at https://developer.apple.com → Certificates, Identifiers & Profiles
# Services ID (the `client_id`) must match the registered Return URL:
#   https://app.example.com/api/auth/oauth/apple/callback
APPLE_OAUTH_CLIENT_ID=       # services ID, e.g. com.locateflow.web.signin
APPLE_OAUTH_TEAM_ID=         # 10-char team ID from the Apple developer console
APPLE_OAUTH_KEY_ID=          # 10-char key ID of the Sign-in-with-Apple key
APPLE_OAUTH_PRIVATE_KEY=     # full PEM contents; use \n inside env string

# Mobile billing credentials can be added later without blocking the rest of
# the product. Until they are configured, mobile purchase verification and
# store-server reconciliation should stay in a disabled / observability-only
# state.
APPLE_BUNDLE_ID=com.locateflow.mobile
APPLE_APP_STORE_ISSUER_ID=
APPLE_APP_STORE_KEY_ID=
APPLE_APP_STORE_PRIVATE_KEY=
APPLE_APP_STORE_ENVIRONMENT=Production
MOBILE_IOS_PRODUCT_INDIVIDUAL=com.locateflow.individual.monthly
MOBILE_ANDROID_PRODUCT_INDIVIDUAL=locateflow_individual_monthly
GOOGLE_PLAY_PACKAGE_NAME=com.locateflow.mobile
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_PLAY_RTDN_AUDIENCE=https://app.example.com/api/webhooks/playstore

# ── Required: Stripe (web payments) ────────────────────────────────
# Generate the Individual monthly + yearly Prices via:
#   pnpm stripe:sync-prices
# The script prints both IDs — paste them below.
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_INDIVIDUAL=price_xxx               # $7.99 / month
STRIPE_PRICE_INDIVIDUAL_YEARLY=price_xxx        # $79 / year

# ── Required: Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=LocateFlow <noreply@example.com>

# ── Required: File storage (Cloudflare R2, S3-compatible) ─────────
# Create a bucket at https://dash.cloudflare.com → R2, then an API
# token scoped to that bucket. `R2_ENDPOINT` is:
#   https://<account-id>.r2.cloudflarestorage.com
# Egress from R2 is free, which is why we pair it with imgproxy.
R2_ENDPOINT=
R2_REGION=auto
R2_BUCKET=locateflow
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional: public R2.dev URL prefix for already-public buckets, e.g.
#   https://pub-<hash>.r2.dev  — only needed if you expose raw objects.
R2_PUBLIC_BASE_URL=

# ── Required: imgproxy (signed image transforms) ──────────────────
# Key + Salt are HEX strings (each 32 bytes). URLs the app generates
# are HMAC-signed with these; unsigned URLs are rejected by imgproxy.
#   openssl rand -hex 32   # IMGPROXY_KEY
#   openssl rand -hex 32   # IMGPROXY_SALT
IMGPROXY_KEY=
IMGPROXY_SALT=
# Public hostname the browser hits — must match IMG_DOMAIN above.
NEXT_PUBLIC_IMGPROXY_URL=https://img.example.com

# ── Required: GlitchTip (self-hosted, Sentry-API compatible) ──────
# Postgres password for GlitchTip's dedicated DB container.
#   openssl rand -base64 24
GLITCHTIP_DB_PASSWORD=
# Django SECRET_KEY for GlitchTip.
#   openssl rand -hex 32
GLITCHTIP_SECRET_KEY=
# Close open signup after you create the first admin account.
GLITCHTIP_ENABLE_REGISTRATION=false
# How many days of events to retain before GlitchTip prunes.
GLITCHTIP_RETENTION_DAYS=90
# Email sender for GlitchTip alerts. Leave at default unless you want
# a separate From address.
GLITCHTIP_FROM_EMAIL=
# Delivery — "consolemail://" prints to stdout (dev). For real mail,
# use a Resend SMTP relay URL:
#   smtp+tls://resend:<RESEND_API_KEY>@smtp.resend.com:587
GLITCHTIP_EMAIL_URL=consolemail://
# DSN produced by GlitchTip when you create a project in its UI.
# Paste into NEXT_PUBLIC_SENTRY_DSN — the Sentry SDK works as-is
# because GlitchTip implements the Sentry ingest protocol.
NEXT_PUBLIC_SENTRY_DSN=

# ── Optional: Rate-limit Redis (falls back to in-memory) ──────────
# Production should use Upstash so counters survive restarts and are shared.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Optional: Google Maps (address autocomplete) ──────────────────
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
PLACES_AUTOCOMPLETE_ENABLED=true
PLACES_AUTOCOMPLETE_DAILY_USER_LIMIT=250
PLACES_AUTOCOMPLETE_DAILY_IP_LIMIT=1000
PLACES_DETAILS_DAILY_USER_LIMIT=250
PLACES_DETAILS_DAILY_IP_LIMIT=1000

# ── Optional: Slack webhook for admin alerts ──────────────────────
SLACK_WEBHOOK_URL=
