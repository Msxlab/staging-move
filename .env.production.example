# ==================================================================
# LocateFlow — Production environment template
# Copy to `.env.production` and fill in real values before deploying.
# ==================================================================
#
# Generation helpers:
#   Random 32-byte hex (ADMIN_JWT_SECRET):  openssl rand -hex 32
#   Random 64-hex key (FIELD_ENCRYPTION_KEY): openssl rand -hex 32
#   Random base64url secret (CRON_SECRET):  openssl rand -base64 36
#
# ── Required: MySQL ────────────────────────────────────────────────
# DigitalOcean Managed MySQL / external DB deployments should set this.
# Example:
#   DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl-mode=REQUIRED
DATABASE_URL=

# Local Docker MySQL deployments use these instead.
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_password_here
MYSQL_DATABASE=locateflow
MYSQL_USER=locateflow
MYSQL_PASSWORD=CHANGE_ME_strong_user_password_here

# Optional for running a second Dokploy stack on the same server.
# Production can omit these; staging should use unique values to avoid
# container, volume, and compose project name collisions with production.
DOKPLOY_COMPOSE_PROJECT_NAME=locateflow
DOKPLOY_CONTAINER_PREFIX=locateflow

# ── Required: Domains + Caddy TLS ──────────────────────────────────
WEB_DOMAIN=locateflow.com
ADMIN_DOMAIN=admin.example.com
ERRORS_DOMAIN=errors.example.com   # GlitchTip (error tracking)
IMG_DOMAIN=img.example.com         # imgproxy (signed image transforms)
ACME_EMAIL=ops@example.com

# ── Required: App URLs ─────────────────────────────────────────────
APP_URL=https://locateflow.com
NEXT_PUBLIC_APP_URL=https://locateflow.com
NEXT_PUBLIC_ADMIN_URL=https://admin.example.com
# Canonical public origin used by metadata, sitemap, robots, and llms.txt.
# Never use localhost, preview, staging, Vercel preview, or non-HTTPS URLs here.
NEXT_PUBLIC_SITE_URL=https://locateflow.com
SITE_URL=https://locateflow.com
APP_ENV=production

# ── Optional: SEO + Google measurement readiness ───────────────────
# Google Search Console meta verification token. This is rendered as
# <meta name="google-site-verification" ...> when configured.
GOOGLE_SITE_VERIFICATION=
# Prefer GTM for production measurement governance. If GTM is empty and
# GA4 is set, the web app loads direct gtag only after cookie consent.
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Static sitemap lastModified fallback for non-blog pages.
SITE_LAST_MODIFIED=2026-05-01T00:00:00.000Z

# ── Required: Admin auth (min 32 chars) ────────────────────────────
ADMIN_JWT_SECRET=CHANGE_ME_at_least_32_chars_or_openssl_rand_hex_32

# ── Required: User auth (min 32 chars — different from admin!) ─────
USER_JWT_SECRET=CHANGE_ME_at_least_32_chars_or_openssl_rand_hex_32

# ── Required: Admin seed (first login) ─────────────────────────────
# Must contain uppercase, lowercase, digit, special char. Min 16 chars.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=CHANGE_ME_MinSixteen1!

# ── Required: Field encryption (exactly 64 hex chars = 32 bytes) ──
FIELD_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Required: Cron authentication ──────────────────────────────────
# Scheduler (Ofelia / Vercel Cron / external scheduler) uses this to
# hit /api/cron/* endpoints. Generate with: openssl rand -base64 36
CRON_SECRET=CHANGE_ME_openssl_rand_base64_36
# Optional narrower secret for admin backup/retention cron. When set, backup
# cron routes reject CRON_SECRET and require this value instead.
# Generate with: openssl rand -base64 36
BACKUP_CRON_SECRET=CHANGE_ME_openssl_rand_base64_36

# ── Required: Internal webhook secret ──────────────────────────────
# Protects server-to-server internal calls (IP rule cache refresh,
# rate-limit log fan-out, cross-app security events).
# Does not fall back to CRON_SECRET. Generate independently so rotating
# scheduler auth doesn't disrupt internal calls and vice versa.
# Generate with: openssl rand -base64 36
INTERNAL_WEBHOOK_SECRET=CHANGE_ME_openssl_rand_base64_36

# ── Required: Impersonation handoff secret ─────────────────────────
# Gates the admin→web /api/internal/impersonate endpoint. A compromised
# CRON_SECRET must NOT grant the ability to mint impersonation sessions.
# Required for admin impersonation. This does not fall back to CRON_SECRET.
# Generate with: openssl rand -base64 36
IMPERSONATION_HANDOFF_SECRET=CHANGE_ME_openssl_rand_base64_36

# ── OAuth: Google (optional but recommended) ──────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services
# Authorized redirect URI: https://app.example.com/api/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── OAuth: Apple (optional, mandatory for iOS App Store) ──────────
# Set up at https://developer.apple.com → Certificates, Identifiers & Profiles
# Services ID (the `client_id`) must match the registered Return URL:
#   https://app.example.com/api/auth/oauth/apple/callback
APPLE_OAUTH_CLIENT_ID=       # services ID, e.g. com.locateflow.web.signin
APPLE_OAUTH_TEAM_ID=         # 10-char team ID from the Apple developer console
APPLE_OAUTH_KEY_ID=          # 10-char key ID of the Sign-in-with-Apple key
APPLE_OAUTH_PRIVATE_KEY=     # full PEM contents; use \n inside env string
# 10-char team ID used in /.well-known/apple-app-site-association.
APPLE_TEAM_ID=

# Mobile billing credentials can be added later without blocking the rest of
# the product. Until they are configured, mobile purchase verification and
# store-server reconciliation should stay in a disabled / observability-only
# state.
APPLE_BUNDLE_ID=com.locateflow.mobile
APPLE_APP_STORE_ISSUER_ID=
APPLE_APP_STORE_KEY_ID=
APPLE_APP_STORE_PRIVATE_KEY=
APPLE_APP_STORE_ENVIRONMENT=Production
MOBILE_IOS_PRODUCT_INDIVIDUAL=com.locateflow.mobile.individual.monthly        # $4.99 / month
MOBILE_IOS_PRODUCT_INDIVIDUAL_YEARLY=com.locateflow.mobile.individual.annual  # $24 / year
MOBILE_IOS_PRODUCT_FAMILY=com.locateflow.mobile.family.monthly                # $7.99 / month
MOBILE_IOS_PRODUCT_FAMILY_YEARLY=com.locateflow.mobile.family.annual          # $39 / year App Store tier
MOBILE_IOS_PRODUCT_PRO=com.locateflow.mobile.pro.monthly                      # $11.99 / month
MOBILE_IOS_PRODUCT_PRO_YEARLY=com.locateflow.mobile.pro.annual                # $59 / year App Store tier
MOBILE_ANDROID_PRODUCT_INDIVIDUAL=locateflow_individual_monthly               # $4.99 / month base plan
MOBILE_ANDROID_PRODUCT_INDIVIDUAL_YEARLY=locateflow_individual_annual         # $24 / year base plan
MOBILE_ANDROID_PRODUCT_FAMILY=locateflow_family_monthly                       # $7.99 / month base plan
MOBILE_ANDROID_PRODUCT_FAMILY_YEARLY=locateflow_family_annual                 # $39 / year base plan
MOBILE_ANDROID_PRODUCT_PRO=locateflow_pro_monthly                             # $11.99 / month base plan
MOBILE_ANDROID_PRODUCT_PRO_YEARLY=locateflow_pro_annual                       # $59 / year base plan
GOOGLE_PLAY_PACKAGE_NAME=com.locateflow.mobile
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_PLAY_RTDN_AUDIENCE=https://app.example.com/api/webhooks/playstore
EXPECTED_PLAYSTORE_WEBHOOK_SERVICE_ACCOUNT_EMAIL=

# Partner address-update connectors.
# Keep disabled until partner/legal approval is complete. Annual Pro
# entitlement, per-partner consent, and connector rollout controls still apply.
FEATURE_API_CONNECTORS=false
# Master switch for the Family/Pro multi-member Workspace (shared addresses,
# services, household budget, member roles). When false, /api/workspaces 404s
# and Family/Pro behave like Individual. Toggle from admin Runtime Config or set
# here. Run the migrate-to-workspaces backfill BEFORE flipping to true so
# existing Family/Pro owners get a workspace and their records are stamped.
WORKSPACE_MODEL_ENABLED=false
# Optional per-partner credentials. Use deployment env or Runtime Config.
# CONNECTOR_USPS_OAUTH_CLIENT_ID=
# CONNECTOR_USPS_OAUTH_CLIENT_SECRET=
# CONNECTOR_USPS_OAUTH_AUTHORIZE_URL=https://apis.usps.com/oauth/authorize
# CONNECTOR_USPS_OAUTH_TOKEN_URL=https://apis.usps.com/oauth/token
# CONNECTOR_USPS_OAUTH_SCOPES="addresses change-of-address"
# CONNECTOR_USPS_WEBHOOK_SECRET=

# ── Required: Stripe (web payments) ────────────────────────────────
# Generate the Individual monthly + yearly Prices via:
#   pnpm stripe:sync-prices
# The script prints both IDs — paste them below.
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_PRICE_INDIVIDUAL_MONTHLY=price_xxx       # $4.99 / month
STRIPE_PRICE_INDIVIDUAL_YEARLY=price_xxx        # $24 / year (with 14-day trial)
STRIPE_ANNUAL_TRIAL_DAYS=14

# Native app install prompts / iOS Safari Smart App Banner.
# Leave store URLs empty during closed beta to route users to the waitlist.
NEXT_PUBLIC_IOS_APP_STORE_URL=
NEXT_PUBLIC_ANDROID_PLAY_STORE_URL=
NEXT_PUBLIC_IOS_APP_STORE_ID=

# ── Required: Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=LocateFlow <noreply@example.com>
SUPPORT_EMAIL=support@locateflow.com

# Required before public launch: public legal/contact details
NEXT_PUBLIC_LEGAL_ENTITY_NAME=
NEXT_PUBLIC_COMPANY_ADDRESS=
NEXT_PUBLIC_SUPPORT_EMAIL=support@locateflow.com
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@locateflow.com
NEXT_PUBLIC_LEGAL_NOTICE_EMAIL=legal@locateflow.com
NEXT_PUBLIC_BILLING_EMAIL=billing@locateflow.com
NEXT_PUBLIC_SECURITY_EMAIL=security@locateflow.com
NEXT_PUBLIC_DPA_EMAIL=privacy@locateflow.com

# ── Required: File storage (Cloudflare R2, S3-compatible) ─────────
# Create a bucket at https://dash.cloudflare.com → R2, then an API
# token scoped to that bucket. `R2_ENDPOINT` is:
#   https://<account-id>.r2.cloudflarestorage.com
# Egress from R2 is free, which is why we pair it with imgproxy.
R2_ENDPOINT=
R2_REGION=auto
R2_BUCKET=locateflow
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional: public R2.dev URL prefix for already-public buckets, e.g.
#   https://pub-<hash>.r2.dev  — only needed if you expose raw objects.
R2_PUBLIC_BASE_URL=

# ── Required: imgproxy (signed image transforms) ──────────────────
# Key + Salt are HEX strings (each 32 bytes). URLs the app generates
# are HMAC-signed with these; unsigned URLs are rejected by imgproxy.
#   openssl rand -hex 32   # IMGPROXY_KEY
#   openssl rand -hex 32   # IMGPROXY_SALT
IMGPROXY_KEY=
IMGPROXY_SALT=
# Public hostname the browser hits — must match IMG_DOMAIN above.
NEXT_PUBLIC_IMGPROXY_URL=https://img.example.com

# ── Required: GlitchTip (self-hosted, Sentry-API compatible) ──────
# Postgres password for GlitchTip's dedicated DB container.
#   openssl rand -base64 24
GLITCHTIP_DB_PASSWORD=
# Django SECRET_KEY for GlitchTip.
#   openssl rand -hex 32
GLITCHTIP_SECRET_KEY=
# Close open signup after you create the first admin account.
GLITCHTIP_ENABLE_REGISTRATION=false
# How many days of events to retain before GlitchTip prunes.
GLITCHTIP_RETENTION_DAYS=90
# Email sender for GlitchTip alerts. Leave at default unless you want
# a separate From address.
GLITCHTIP_FROM_EMAIL=
# Delivery — "consolemail://" prints to stdout (dev). For real mail,
# use a Resend SMTP relay URL:
#   smtp+tls://resend:<RESEND_API_KEY>@smtp.resend.com:587
GLITCHTIP_EMAIL_URL=consolemail://
# DSN produced by GlitchTip when you create a project in its UI.
# Paste into NEXT_PUBLIC_SENTRY_DSN — the Sentry SDK works as-is
# because GlitchTip implements the Sentry ingest protocol.
NEXT_PUBLIC_SENTRY_DSN=

# ── Distributed rate-limit Redis ──────────────────────────────────
# REQUIRED in production. The in-memory fallback is per-process, so a
# multi-replica deploy without Upstash multiplies the effective limit by
# the replica count. Without these vars the limiter still serves traffic
# but emits LIMITER_DEGRADED and the health endpoint flags productionEnvOk:false.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Rate-limit shadow rollout flag. When "true", middleware additionally
# evaluates the user_read policy keyed by userId in shadow mode (no
# blocking; emits RATE_LIMIT_SHADOW_HIT). Recommended on for the
# 30-day baseline period before any promotion to enforce.
RATE_LIMIT_SHADOW_USER_KEYED_ENABLED=false

# ── Optional: Google Maps (address autocomplete) ──────────────────
# Server-side Places Web Service key. Do not use a browser HTTP-referrer-
# restricted key here; use API restrictions plus server/IP restrictions when
# your hosting platform provides stable egress IPs.
GOOGLE_MAPS_API_KEY=
# Optional browser key for client-side Maps JavaScript usage.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional server-side Geoapify Static Maps key for route-map PNG proxying.
GEOAPIFY_API_KEY=
PLACES_AUTOCOMPLETE_ENABLED=true
PLACES_AUTOCOMPLETE_DAILY_USER_LIMIT=250
PLACES_AUTOCOMPLETE_DAILY_IP_LIMIT=1000
PLACES_DETAILS_DAILY_USER_LIMIT=250
PLACES_DETAILS_DAILY_IP_LIMIT=1000

# ── Optional: Slack webhook for admin alerts ──────────────────────
SLACK_WEBHOOK_URL=

# ============================================================
# Hidden / advanced
# ------------------------------------------------------------
# Optional knobs read by code but normally left unset. Document the
# defaults / triggers so operators don't discover them by accident.
# ============================================================

# Signs single-use unsubscribe URLs in transactional emails. If unset,
# unsubscribe URLs fall back to a weaker key derivation or fail to sign.
# Set when you want one-click unsubscribe to verify cleanly.
EMAIL_UNSUBSCRIBE_SECRET=

# Comma-separated allowlist of redirect URIs the mobile OAuth handoff
# will accept (e.g. "locateflow://oauth"). Empty disables mobile OAuth.
MOBILE_OAUTH_REDIRECT_URIS=

# Internal URL the admin app uses to call the web app for the
# impersonate handoff. Defaults to NEXT_PUBLIC_APP_URL when unset.
# Set explicitly when admin and web run on different internal hosts.
WEB_INTERNAL_URL=

# Break-glass overrides for the Stripe webhook environment-mismatch
# guard. Both default to off — leave unset in production. Set to "true"
# only when intentionally replaying live events against a staging
# environment for a recovery drill.
STRIPE_ALLOW_LIVE_WEBHOOKS_OUTSIDE_PRODUCTION=
ALLOW_STRIPE_LIVE_EVENTS_IN_NON_PRODUCTION=

# Default currency for new acquisition campaigns. Defaults to "usd"
# when unset. Override when launching a non-USD campaign.
STRIPE_CAMPAIGN_CURRENCY=

# Default currency for ad-hoc Stripe operations (legacy fallback).
# Defaults to "usd" when unset.
STRIPE_CURRENCY=

# Master switch that lets the admin Runtime Config UI override
# deployment-env Stripe keys for break-glass rotation. Defaults to off.
# Set to "true" only during a controlled key rotation and unset right after.
STRIPE_RUNTIME_CONFIG_OVERRIDE_ENABLED=

# Cookie-domain overrides for session cookies. Defaults: host-only on
# the request hostname plus ".locateflow.com" for cross-subdomain
# sessions. Set explicitly when admin and web share auth across a
# different parent domain.
ADMIN_SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_DOMAIN=
USER_SESSION_COOKIE_DOMAIN=

# Bing IndexNow API key used to ping the search engine when blog
# content changes. Optional — leave unset to skip IndexNow notifications.
INDEXNOW_KEY=

# SMS notification feature flag. Defaults to off. SMS provider wiring is
# not implemented yet; set to "true" only when integrating one.
NOTIFICATION_SMS_ENABLED=

# DEPRECATED alias for GOOGLE_SITE_VERIFICATION. Read by seo.ts as a
# fallback. Prefer the non-public name above; remove once operators have
# migrated.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
