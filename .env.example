# ============================================================
# LocateFlow Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit real secrets — use placeholder format below.
# ============================================================

# Database (MySQL 8.0 via Docker)
DATABASE_URL="mysql://locateflow:YOUR_DB_PASSWORD@localhost:3306/locateflow"

# Clerk Authentication
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/onboarding"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_YOUR_CLERK_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="sk_test_YOUR_CLERK_SECRET_KEY"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# Cloudinary
CLOUDINARY_CLOUD_NAME="YOUR_CLOUD_NAME"
CLOUDINARY_API_KEY="YOUR_CLOUDINARY_API_KEY"
CLOUDINARY_API_SECRET="YOUR_CLOUDINARY_API_SECRET"

# Stripe
STRIPE_SECRET_KEY="sk_test_YOUR_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="whsec_YOUR_STRIPE_WEBHOOK_SECRET"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_YOUR_STRIPE_PUBLISHABLE_KEY"
STRIPE_PRICE_INDIVIDUAL="price_YOUR_INDIVIDUAL_PRICE_ID"
STRIPE_PRICE_FAMILY="price_YOUR_FAMILY_PRICE_ID"

# Native Mobile Billing
MOBILE_IOS_PRODUCT_INDIVIDUAL="com.locateflow.individual.monthly"
MOBILE_IOS_PRODUCT_FAMILY="com.locateflow.family.monthly"
MOBILE_ANDROID_PRODUCT_INDIVIDUAL="locateflow_individual_monthly"
MOBILE_ANDROID_PRODUCT_FAMILY="locateflow_family_monthly"
APPLE_BUNDLE_ID="com.locateflow.mobile"
APPLE_APP_STORE_ISSUER_ID="YOUR_APP_STORE_ISSUER_ID"
APPLE_APP_STORE_KEY_ID="YOUR_APP_STORE_KEY_ID"
APPLE_APP_STORE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_APP_STORE_PRIVATE_KEY\n-----END PRIVATE KEY-----"
GOOGLE_PLAY_PACKAGE_NAME="com.locateflow.mobile"
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL="google-play-service-account@your-project.iam.gserviceaccount.com"
GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_GOOGLE_PLAY_PRIVATE_KEY\n-----END PRIVATE KEY-----"

# Admin (apps/admin)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET="YOUR_RANDOM_SECRET_AT_LEAST_32_CHARS"

# Admin Seed (packages/db)
ADMIN_SEED_EMAIL="admin@locateflow.com"
# Must be 16+ chars with uppercase, lowercase, digit, and special character
ADMIN_SEED_PASSWORD="YOUR_STRONG_ADMIN_PASSWORD_HERE"

# Resend Email
RESEND_API_KEY="re_YOUR_RESEND_API_KEY"
EMAIL_FROM="LocateFlow <noreply@yourdomain.com>"
ALERT_EMAIL_FROM="LocateFlow Security <security@yourdomain.com>"
ALERT_EMAIL_TO="security@yourdomain.com,ops@yourdomain.com"

# Security / Incident Monitoring
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
NEXT_PUBLIC_SENTRY_DSN="https://YOUR_PUBLIC_KEY@o0.ingest.sentry.io/0"

# Upstash Redis (Rate Limiting) — REQUIRED for production
UPSTASH_REDIS_REST_URL="https://YOUR_INSTANCE.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_TOKEN"

# Backup Storage (recommended for production-grade offsite encrypted backups)
BACKUP_STORAGE_PROVIDER="s3"
BACKUP_STORAGE_BUCKET="locateflow-backups"
BACKUP_STORAGE_REGION="us-east-1"
BACKUP_STORAGE_ENDPOINT="https://s3.amazonaws.com"
BACKUP_STORAGE_ACCESS_KEY_ID="YOUR_BACKUP_STORAGE_ACCESS_KEY_ID"
BACKUP_STORAGE_SECRET_ACCESS_KEY="YOUR_BACKUP_STORAGE_SECRET_ACCESS_KEY"

# Cron Jobs
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="YOUR_CRON_SECRET_MIN_32_CHARS"

# Development Only — set to "true" to enable dev auth bypass without Clerk
# WARNING: NEVER set this in production
DEV_AUTH_BYPASS="false"

# OpenAI (AI Assistant)
OPENAI_API_KEY="sk-YOUR_OPENAI_API_KEY"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
