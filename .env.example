# ============================================================
# LocateFlow Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit real secrets — use placeholder format below.
# ============================================================

# Database (MySQL 8.0 via Docker)
DATABASE_URL="mysql://locateflow:YOUR_DB_PASSWORD@localhost:3306/locateflow"

# JWT Authentication
USER_JWT_SECRET="YOUR_USER_JWT_SECRET_AT_LEAST_32_CHARS"
ADMIN_JWT_SECRET="YOUR_ADMIN_JWT_SECRET_AT_LEAST_32_CHARS"
FIELD_ENCRYPTION_KEY="YOUR_64_CHAR_HEX_FIELD_ENCRYPTION_KEY"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
SITE_URL="http://localhost:3000"
APP_ENV="development"

# SEO / Google readiness (tokens and IDs are public once rendered; keep real values in deployment env)
GOOGLE_SITE_VERIFICATION=""
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
SITE_LAST_MODIFIED="2026-05-01T00:00:00.000Z"

# Social Sign-In (web + mobile handoff)
# Leave blank until provider credentials are ready. Google / Apple sign-in
# stays disabled until these values are configured.
GOOGLE_OAUTH_CLIENT_ID="YOUR_GOOGLE_OAUTH_CLIENT_ID"
GOOGLE_OAUTH_CLIENT_SECRET="YOUR_GOOGLE_OAUTH_CLIENT_SECRET"
APPLE_OAUTH_CLIENT_ID="YOUR_APPLE_OAUTH_CLIENT_ID"
APPLE_OAUTH_TEAM_ID="YOUR_APPLE_OAUTH_TEAM_ID"
APPLE_OAUTH_KEY_ID="YOUR_APPLE_OAUTH_KEY_ID"
APPLE_OAUTH_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_APPLE_OAUTH_PRIVATE_KEY\n-----END PRIVATE KEY-----"

# Google Maps
GOOGLE_MAPS_API_KEY="YOUR_SERVER_SIDE_GOOGLE_MAPS_API_KEY"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"
PLACES_AUTOCOMPLETE_ENABLED="true"
PLACES_AUTOCOMPLETE_DAILY_USER_LIMIT="250"
PLACES_AUTOCOMPLETE_DAILY_IP_LIMIT="1000"
PLACES_DETAILS_DAILY_USER_LIMIT="250"
PLACES_DETAILS_DAILY_IP_LIMIT="1000"

# File storage — Cloudflare R2 (S3-compatible, $0 egress)
R2_ENDPOINT="https://YOUR_ACCOUNT.r2.cloudflarestorage.com"
R2_REGION="auto"
R2_BUCKET="locateflow-dev"
R2_ACCESS_KEY_ID="YOUR_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="YOUR_R2_SECRET_ACCESS_KEY"
R2_PUBLIC_BASE_URL=""

# imgproxy — signs image URLs so unsigned requests are rejected
# Generate each with: openssl rand -hex 32
IMGPROXY_KEY="YOUR_IMGPROXY_HEX_KEY"
IMGPROXY_SALT="YOUR_IMGPROXY_HEX_SALT"
# Public hostname the browser hits; Caddy routes this to imgproxy:8080.
NEXT_PUBLIC_IMGPROXY_URL="https://img.yourdomain.com"

# Stripe
STRIPE_SECRET_KEY="sk_test_YOUR_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="whsec_YOUR_STRIPE_WEBHOOK_SECRET"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_YOUR_STRIPE_PUBLISHABLE_KEY"
STRIPE_PRICE_INDIVIDUAL_MONTHLY="price_YOUR_INDIVIDUAL_MONTHLY_PRICE_ID"
STRIPE_PRICE_INDIVIDUAL_YEARLY="price_YOUR_INDIVIDUAL_YEARLY_PRICE_ID"
STRIPE_ANNUAL_TRIAL_DAYS="90"

# Native Mobile Billing
MOBILE_IOS_PRODUCT_INDIVIDUAL="com.locateflow.individual.monthly"
MOBILE_IOS_PRODUCT_FAMILY="com.locateflow.family.monthly"
MOBILE_ANDROID_PRODUCT_INDIVIDUAL="locateflow_individual_monthly"
MOBILE_ANDROID_PRODUCT_FAMILY="locateflow_family_monthly"
APPLE_BUNDLE_ID="com.locateflow.mobile"
APPLE_APP_STORE_ISSUER_ID="YOUR_APP_STORE_ISSUER_ID"
APPLE_APP_STORE_KEY_ID="YOUR_APP_STORE_KEY_ID"
APPLE_APP_STORE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_APP_STORE_PRIVATE_KEY\n-----END PRIVATE KEY-----"
APPLE_APP_STORE_ENVIRONMENT="Sandbox"
GOOGLE_PLAY_PACKAGE_NAME="com.locateflow.mobile"
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL="google-play-service-account@your-project.iam.gserviceaccount.com"
GOOGLE_PLAY_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_GOOGLE_PLAY_PRIVATE_KEY\n-----END PRIVATE KEY-----"
GOOGLE_PLAY_RTDN_AUDIENCE="https://locateflow.com/api/webhooks/playstore"
EXPECTED_PLAYSTORE_WEBHOOK_SERVICE_ACCOUNT_EMAIL="rtdn-push@your-project.iam.gserviceaccount.com"

# Admin Seed (packages/db)
ADMIN_SEED_EMAIL="admin@locateflow.com"
# Must be 16+ chars with uppercase, lowercase, digit, and special character
ADMIN_SEED_PASSWORD="YOUR_STRONG_ADMIN_PASSWORD_HERE"

# Resend Email
RESEND_API_KEY="re_YOUR_RESEND_API_KEY"
EMAIL_FROM="LocateFlow <noreply@yourdomain.com>"
ALERT_EMAIL_FROM="LocateFlow Security <security@yourdomain.com>"
ALERT_EMAIL_TO="security@yourdomain.com,ops@yourdomain.com"

# Public legal/contact details shown on policy pages
NEXT_PUBLIC_LEGAL_ENTITY_NAME="[Legal entity name to be finalized]"
NEXT_PUBLIC_COMPANY_ADDRESS="[Mailing address to be finalized before production launch]"
NEXT_PUBLIC_SUPPORT_EMAIL="support@locateflow.com"
NEXT_PUBLIC_PRIVACY_EMAIL="privacy@locateflow.com"
NEXT_PUBLIC_LEGAL_NOTICE_EMAIL="legal@locateflow.com"
NEXT_PUBLIC_BILLING_EMAIL="billing@locateflow.com"
NEXT_PUBLIC_SECURITY_EMAIL="security@locateflow.com"
NEXT_PUBLIC_DPA_EMAIL="privacy@locateflow.com"

# Security / Incident Monitoring
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
NEXT_PUBLIC_SENTRY_DSN="https://YOUR_PUBLIC_KEY@o0.ingest.sentry.io/0"

# Upstash Redis (Rate Limiting) — REQUIRED for production
# In-memory fallback is intentional for local dev only; multi-replica
# deployments will multiply the effective limit per replica without Redis.
UPSTASH_REDIS_REST_URL="https://YOUR_INSTANCE.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_TOKEN"

# Rate-limit shadow rollout — when "true", middleware also evaluates the
# user_read policy keyed by userId in shadow mode (no blocking, signals via
# RATE_LIMIT_SHADOW_HIT). Run for 30 days in production before considering
# promotion to enforce. Default off to keep the audit zero-overhead until
# ops opts in.
RATE_LIMIT_SHADOW_USER_KEYED_ENABLED="false"

# Backup Storage (recommended for production-grade offsite encrypted backups)
BACKUP_STORAGE_PROVIDER="s3"
BACKUP_STORAGE_BUCKET="locateflow-backups"
BACKUP_STORAGE_REGION="us-east-1"
BACKUP_STORAGE_ENDPOINT="https://s3.amazonaws.com"
BACKUP_STORAGE_ACCESS_KEY_ID="YOUR_BACKUP_STORAGE_ACCESS_KEY_ID"
BACKUP_STORAGE_SECRET_ACCESS_KEY="YOUR_BACKUP_STORAGE_SECRET_ACCESS_KEY"

# Cron Jobs — scheduler auth for /api/cron/*
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="YOUR_CRON_SECRET_MIN_32_CHARS"

# Internal server-to-server webhook auth (IP rule cache refresh,
# rate-limit log fan-out, admin→admin security events).
# Required for internal webhooks. Does not fall back to CRON_SECRET; keep it
# independently rotatable from scheduler auth.
INTERNAL_WEBHOOK_SECRET="YOUR_INTERNAL_WEBHOOK_SECRET_MIN_32_CHARS"

# Admin→web impersonation handoff auth.
# Required for admin impersonation. Does not fall back to CRON_SECRET; a leaked
# scheduler secret must not grant impersonation power.
IMPERSONATION_HANDOFF_SECRET="YOUR_IMPERSONATION_HANDOFF_SECRET_MIN_32_CHARS"

# ============================================================
# Hidden / advanced
# ------------------------------------------------------------
# Optional knobs read by code but normally left unset. Document the
# defaults / triggers so operators don't discover them by accident.
# ============================================================

# Signs single-use unsubscribe URLs in transactional emails. If unset,
# unsubscribe URLs fall back to a weaker key derivation or fail to sign.
# Set when you want one-click unsubscribe to verify cleanly.
EMAIL_UNSUBSCRIBE_SECRET=""

# Comma-separated allowlist of redirect URIs the mobile OAuth handoff
# will accept (e.g. "locateflow://oauth,exp://192.168.1.5:8081"). Empty
# disables mobile OAuth handoff.
MOBILE_OAUTH_REDIRECT_URIS=""

# Internal URL the admin app uses to call the web app for the
# impersonate handoff. Defaults to NEXT_PUBLIC_APP_URL when unset.
# Set explicitly when admin and web run on different internal hosts.
WEB_INTERNAL_URL=""

# Break-glass overrides for the Stripe webhook environment-mismatch
# guard. Both default to off — leave unset in production. Set to "true"
# only when intentionally replaying live events against a staging
# environment for a recovery drill.
STRIPE_ALLOW_LIVE_WEBHOOKS_OUTSIDE_PRODUCTION=""
ALLOW_STRIPE_LIVE_EVENTS_IN_NON_PRODUCTION=""

# Default currency for new acquisition campaigns. Defaults to "usd"
# when unset. Override when launching a non-USD campaign.
STRIPE_CAMPAIGN_CURRENCY=""

# Default currency for ad-hoc Stripe operations (legacy fallback).
# Defaults to "usd" when unset.
STRIPE_CURRENCY=""

# Master switch that lets the admin Runtime Config UI override
# deployment-env Stripe keys for break-glass rotation. Defaults to off.
# Set to "true" only during a controlled key rotation and unset right after.
STRIPE_RUNTIME_CONFIG_OVERRIDE_ENABLED=""

# Cookie-domain overrides for session cookies. Defaults: host-only on
# the request hostname plus ".locateflow.com" for cross-subdomain
# sessions. Set explicitly when admin and web share auth across a
# different parent domain.
ADMIN_SESSION_COOKIE_DOMAIN=""
SESSION_COOKIE_DOMAIN=""
USER_SESSION_COOKIE_DOMAIN=""

# Bing IndexNow API key used to ping the search engine when blog
# content changes. Optional — leave unset to skip IndexNow notifications.
INDEXNOW_KEY=""

# SMS notification feature flag. Defaults to off. SMS provider wiring is
# not implemented yet; set to "true" only when integrating one.
NOTIFICATION_SMS_ENABLED=""

# DEPRECATED alias for GOOGLE_SITE_VERIFICATION. Read by seo.ts as a
# fallback. Prefer the non-public name above; remove this line once
# operators have migrated.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
