# LocateFlow web app — example environment variables.
# See the repository-root .env.example for the full catalog. This file
# documents the public legal/contact details that must be finalized before
# a production-like launch. When these are unset, legal-info.ts falls back to
# placeholder strings and the production readiness check fails.

# Public legal/contact details shown on policy and billing pages.
# Both are required in production: leaving them unset ships the
# "[... to be finalized]" placeholder text and fails /api/ready.
# Real values come from the business — do NOT guess.
NEXT_PUBLIC_LEGAL_ENTITY_NAME="[Legal entity name to be finalized]"
NEXT_PUBLIC_COMPANY_ADDRESS="[Mailing address to be finalized before production launch]"
