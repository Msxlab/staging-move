{
  "expo": {
    "name": "LocateFlow",
    "slug": "locateflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "locateflow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0A07"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.locateflow.mobile",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:locateflow.com",
        "applinks:locateflow.app",
        "applinks:app.locateflow.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0A07"
      },
      "package": "com.locateflow.mobile",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "locateflow.com",
              "pathPrefix": "/blog"
            },
            {
              "scheme": "https",
              "host": "locateflow.com",
              "pathPrefix": "/mobile/oauth"
            },
            {
              "scheme": "https",
              "host": "locateflow.com",
              "pathPrefix": "/reset-password"
            },
            {
              "scheme": "https",
              "host": "locateflow.app",
              "pathPrefix": "/blog"
            },
            {
              "scheme": "https",
              "host": "locateflow.app",
              "pathPrefix": "/mobile/oauth"
            },
            {
              "scheme": "https",
              "host": "locateflow.app",
              "pathPrefix": "/reset-password"
            },
            {
              "scheme": "https",
              "host": "app.locateflow.com",
              "pathPrefix": "/blog"
            },
            {
              "scheme": "https",
              "host": "app.locateflow.com",
              "pathPrefix": "/mobile/oauth"
            },
            {
              "scheme": "https",
              "host": "app.locateflow.com",
              "pathPrefix": "/reset-password"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "INTERNET",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#D4846A"
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.2.0"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aa33b70b-8158-4b17-944d-a34a03fc6b42"
      }
    },
    "owner": "msxlab"
  }
}
