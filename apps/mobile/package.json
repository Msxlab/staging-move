{
  "name": "@locateflow/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "dev:client": "expo start --dev-client",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:dev:android": "eas build --profile development -p android",
    "build:dev:ios": "eas build --profile development -p ios",
    "build:simulator:ios": "eas build --profile development-simulator -p ios",
    "build:android": "eas build -p android",
    "build:ios": "eas build -p ios",
    "update:preview": "eas update --channel preview --environment preview",
    "update:production": "eas update --channel production --environment production",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "expo": {
    "autolinking": {
      "exclude": [
        "react"
      ]
    },
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@expo-google-fonts/fraunces": "^0.4.0",
    "@expo-google-fonts/geist": "^0.4.2",
    "@expo-google-fonts/geist-mono": "^0.4.2",
    "@expo/metro-runtime": "^55.0.11",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^3.9.0",
    "@locateflow/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/react-query": "^5.100.14",
    "expo": "~55.0.26",
    "expo-apple-authentication": "~55.0.13",
    "expo-auth-session": "~55.0.16",
    "expo-blur": "~55.0.14",
    "expo-build-properties": "~55.0.14",
    "expo-clipboard": "^55.0.13",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-device": "~55.0.17",
    "expo-file-system": "~55.0.22",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.14",
    "expo-iap": "^2.8.0",
    "expo-image": "~55.0.11",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-local-authentication": "~55.0.14",
    "expo-localization": "^55.0.15",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "expo-updates": "~55.0.24",
    "expo-web-browser": "~55.0.16",
    "i18next": "^26.2.0",
    "lucide-react-native": "^0.563.0",
    "nativewind": "^4.2.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.76.1",
    "react-i18next": "^17.0.8",
    "react-native": "0.83.6",
    "react-native-android-widget": "^0.20.3",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.4",
    "zod": "^3.24.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@bacons/apple-targets": "^4.0.7",
    "@types/react": "~19.2.15",
    "eas-cli": "^16.24.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.3.0",
    "vitest": "^4.1.7"
  }
}
