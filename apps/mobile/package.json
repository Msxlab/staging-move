{
  "name": "@locateflow/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:client": "expo start --dev-client",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:dev:android": "eas build --profile development -p android",
    "build:dev:ios": "eas build --profile development -p ios",
    "build:simulator:ios": "eas build --profile development-simulator -p ios",
    "build:android": "eas build -p android",
    "build:ios": "eas build -p ios",
    "update:preview": "eas update --channel preview --environment preview",
    "update:production": "eas update --channel production --environment production",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "expo": {
    "autolinking": {
      "exclude": [
        "react"
      ]
    },
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo-google-fonts/fraunces": "^0.4.0",
    "@expo-google-fonts/geist": "^0.4.2",
    "@expo-google-fonts/geist-mono": "^0.4.2",
    "@expo/metro-runtime": "^6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^3.9.0",
    "@locateflow/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.100.11",
    "expo": "~55.0.25",
    "expo-apple-authentication": "~8.0.7",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.9",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.8",
    "expo-haptics": "~15.0.8",
    "expo-iap": "^2.8.0",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "^17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~55.0.24",
    "expo-web-browser": "~55.0.16",
    "i18next": "^26.2.0",
    "lucide-react-native": "^0.563.0",
    "nativewind": "^4.2.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.76.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.25.1",
    "react-native-svg": "15.15.5",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "zod": "^3.24.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.2.14",
    "eas-cli": "^16.24.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.3.0",
    "vitest": "^4.1.6"
  }
}
