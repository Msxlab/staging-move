# Admin Panel Environment Variables
# The datasource is MySQL (packages/db/prisma/schema.prisma) — must match the
# web app's DATABASE_URL. The old SQLite "file:" URL here was stale/misleading.
DATABASE_URL="mysql://user:password@localhost:3306/locateflow"
ADMIN_JWT_SECRET="change-this-to-a-secure-secret-in-production"
