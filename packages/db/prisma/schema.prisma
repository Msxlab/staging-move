  id       String        @id @default(cuid()) @db.VarChar(30)
  ticketId String        @db.VarChar(30)
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // Who sent the message
  senderType String @db.VarChar(10) // USER, ADMIN, SYSTEM
  senderId   String @db.VarChar(30) // userId or adminUserId

  content       String  @db.Text
  // Optional file attachment (Cloudinary URL)
  attachmentUrl String? @db.VarChar(500)

  isInternal Boolean @default(false) // Admin-only internal notes, not visible to user

  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
  @@index([senderId])
}

// Waitlist signups — captured from marketing pages for things that aren't
// live yet (mobile apps, Family plan, Pro plan, API access).
// Kept in a single table with a `target` discriminator so admin can pull
// per-segment counts without scanning separate tables.
model WaitlistSignup {
  id     String  @id @default(cuid()) @db.VarChar(30)
  email  String  @db.VarChar(255)
  target String  @db.VarChar(30) // MOBILE_IOS, MOBILE_ANDROID, MOBILE_ANY, PLAN_FAMILY, PLAN_PRO, API_ACCESS
  source String? @db.VarChar(60) // landing-hero, pricing-family, pricing-pro, contact-form, ...

  // Optional free-form note from the user ("I manage 40 rentals", etc.)
  // Useful for prioritizing Pro / API outreach.
  note String? @db.Text

  // Basic context captured at signup — helps admin triage and dedupe.
  ipHash    String? @db.VarChar(64) // SHA-256 of request IP (privacy-friendly)
  userAgent String? @db.VarChar(500)
  locale    String? @db.VarChar(10)

  // If the signup happens while the user is logged in, tie it back so admin
  // can reach out through the existing account path.
  userId String? @db.VarChar(30)

  // Outreach tracking — admin marks when a waitlist entry is contacted.
  notifiedAt  DateTime?
  convertedAt DateTime? // User eventually subscribed / downloaded the app

  createdAt DateTime @default(now())

  @@unique([email, target])
  @@index([target, createdAt])
  @@index([userId])
}

// ==================== BLOG (M14) ====================
//
// Public-facing content surface. Source of truth lives here so the
// admin can edit/schedule/translate posts without code deploys, and
// the same data feeds /blog (web), the mobile Blog tab, the homepage
// "Latest" section, and the AI-discovery `/llms.txt` endpoint.
//
// Locale: only `en` and `es` are supported (US market). The
// `[slug, locale]` unique pair lets the same article live in both
// languages without slug collisions; `hreflang` alternates link them.
//
// Security:
//   - `contentJson` is the editor's Tiptap output (canonical).
//   - `contentHtml` is the server-side sanitized render (DOMPurify
//     whitelist) — what we actually inject into pages.
//   - `contentText` is plain text for search and AI crawlers.
// All three are written together in a transaction; never trust
// client-supplied HTML.

enum BlogStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model BlogPost {
  id             String @id @default(cuid()) @db.VarChar(30)
  slug           String @db.VarChar(191)
  locale         String @default("en") @db.VarChar(8) // en | es
  title          String @db.VarChar(200)
  excerpt        String @db.VarChar(500)
  contentJson    Json
  contentHtml    String @db.LongText
  contentText    String @db.LongText
  readingMinutes Int    @default(3)

  // SEO overrides (fall back to title/excerpt when null)
  seoTitle       String? @db.VarChar(200)
  seoDescription String? @db.VarChar(320)
  canonicalUrl   String? @db.VarChar(500)
  noIndex        Boolean @default(false)
  ogImageKey     String? @db.VarChar(500) // R2 object key (signed via imgproxy at render)
  ogImageAlt     String? @db.VarChar(200)

  // Lifecycle
  status      BlogStatus @default(DRAFT)
  publishedAt DateTime?
  scheduledAt DateTime?

  // Authorship + taxonomy
  authorId   String         @db.VarChar(30)
  author     AdminUser      @relation("BlogPostAuthor", fields: [authorId], references: [id])
  categoryId String?        @db.VarChar(30)
  category   BlogCategory?  @relation(fields: [categoryId], references: [id])
  tags       BlogPostTag[]
  revisions  BlogRevision[]
  views      BlogView[]

  // Lightweight stats (denormalized — heavy queries hit BlogView)
  viewCount  Int @default(0)
  shareCount Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([slug, locale])
  @@index([status, publishedAt])
  @@index([locale, status, publishedAt])
  @@index([categoryId])
  @@index([scheduledAt])
  @@index([authorId])
  @@index([deletedAt])
}

model BlogCategory {
  id          String  @id @default(cuid()) @db.VarChar(30)
  slug        String  @db.VarChar(100)
  locale      String  @default("en") @db.VarChar(8)
  name        String  @db.VarChar(100)
  description String? @db.VarChar(500)
  order       Int     @default(0)

  posts BlogPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, locale])
  @@index([locale, order])
}

model BlogTag {
  id     String        @id @default(cuid()) @db.VarChar(30)
  slug   String        @db.VarChar(100)
  locale String        @default("en") @db.VarChar(8)
  name   String        @db.VarChar(100)
  posts  BlogPostTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, locale])
  @@index([locale])
}

model BlogPostTag {
  postId String   @db.VarChar(30)
  tagId  String   @db.VarChar(30)
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

// Snapshot of every save — lets editors roll back, and gives admin a
// changelog for moderation/audit purposes. Cleaned up by cron after
// 90 days for inactive posts to keep the table small.
model BlogRevision {
  id          String    @id @default(cuid()) @db.VarChar(30)
  postId      String    @db.VarChar(30)
  post        BlogPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId    String    @db.VarChar(30)
  author      AdminUser @relation("BlogRevisionAuthor", fields: [authorId], references: [id])
  title       String    @db.VarChar(200)
  contentJson Json
  note        String?   @db.VarChar(500) // optional commit-style message

  createdAt DateTime @default(now())

  @@index([postId, createdAt])
  @@index([authorId])
}

// Lightweight view analytics — privacy-friendly (IP is hashed). The
// `isBot` flag lets us split organic/AI/bot traffic in the admin
// dashboard without storing raw user-agents long-term.
model BlogView {
  id        String   @id @default(cuid()) @db.VarChar(30)
  postId    String   @db.VarChar(30)
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  ipHash    String   @db.VarChar(64) // SHA-256(ip + daily salt)
  userAgent String?  @db.VarChar(300)
  referrer  String?  @db.VarChar(500)
  locale    String?  @db.VarChar(8)
  isBot     Boolean  @default(false)
  viewDay   String   @db.VarChar(10) // UTC yyyy-mm-dd for daily dedupe

  createdAt DateTime @default(now())

  @@unique([postId, ipHash, viewDay])
  @@index([postId, createdAt])
  @@index([createdAt])
}

// ==================== CONNECTOR FRAMEWORK (Faz 2, flag-gated) ====================
// Outbound connector network: propagate an address change to external partners
// (USPS, Amazon, banks, …) through @locateflow/connectors. These three tables
// are self-contained — they reference only User, and keep loose string refs to
// the future AddressChangeEvent / Service so the framework can land before the
// rest of the Family/Pro foundation. Everything stays inert until
// FEATURE_API_CONNECTORS is enabled and a ConnectorConfig row is turned on.

// OAuth/API delegation a user granted for one connector. Holds the encrypted
// token vault entry. Revocable from either side; immutable consent snapshot.
model PartnerConsent {
  id     String @id @default(cuid()) @db.VarChar(30)
  userId String @db.VarChar(30)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Connector manifest key (e.g. "usps") — NOT an FK to the provider catalog,
  // so the framework stays decoupled from ServiceProvider.
  connectorKey String @db.VarChar(40)

  scopesJson String @db.Text // JSON array of granted scopes

  status           String  @db.VarChar(20) // GRANTED | REVOKED | EXPIRED
  revocationReason String? @db.VarChar(40) // USER_REQUESTED | PARTNER_REVOKED | AUTO_EXPIRED | ADMIN_REVOKED | SECURITY_INCIDENT

  grantedAt DateTime
  revokedAt DateTime?
  expiresAt DateTime?

  tokenEncrypted        String?   @db.Text // ACCESS token, encrypted with FIELD_ENCRYPTION_KEY
  refreshTokenEncrypted String?   @db.Text // refresh token, encrypted; mints new access tokens
  tokenExpiresAt        DateTime? // expiry of the ACCESS token above

  consentSnapshotJson String @db.Text // immutable terms + scope shown at grant time

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dispatches ConnectorDispatch[]

  @@index([userId, status])
  @@index([connectorKey, status])
  @@index([status, expiresAt])
}

// Runtime control plane for one connector. Flippable without a deploy: kill
// switch, gradual rollout, lifecycle stage, and a mirror of the breaker state.
model ConnectorConfig {
  id           String @id @default(cuid()) @db.VarChar(30)
  connectorKey String @unique @db.VarChar(40)

  enabled        Boolean @default(false) // kill switch — false drains to fallback
  rolloutPercent Int     @default(0) // 0..100 of eligible users
  circuitState   String  @default("CLOSED") @db.VarChar(20) // CLOSED | OPEN | HALF_OPEN | DISABLED
  stage          String  @default("SHADOW") @db.VarChar(20) // SHADOW | ROLLOUT | GA | RETIRED

  version String  @db.VarChar(20)
  notes   String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
}

// The durable dispatch (transactional-outbox row) carrying one address change
// to one connector. Idempotent; retried with backoff; degrades to NEEDS_USER.
model ConnectorDispatch {
  id           String @id @default(cuid()) @db.VarChar(30)
  connectorKey String @db.VarChar(40)

  userId String @db.VarChar(30)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  consentId String?         @db.VarChar(30)
  consent   PartnerConsent? @relation(fields: [consentId], references: [id], onDelete: SetNull)

  // Loose refs to the future AddressChangeEvent / Service — no FK yet (those
  // models don't exist); tighten when they land.
  eventId   String? @db.VarChar(30)
  serviceId String? @db.VarChar(30)

  idempotencyKey String @unique @db.VarChar(120)

  status        String  @default("QUEUED") @db.VarChar(20) // QUEUED|DISPATCHING|SUBMITTED|CONFIRMED|NEEDS_USER|FAILED
  attemptCount  Int     @default(0)
  lastErrorCode String? @db.VarChar(30) // normalized ConnectorErrorCode

  confirmationEncrypted String? @db.Text // partner confirmation #, encrypted with FIELD_ENCRYPTION_KEY
  resultMetadataJson    String? @db.Text
  // CanonicalAddressChange snapshot, encrypted with FIELD_ENCRYPTION_KEY. Keeps
  // the outbox row self-contained so the worker can run without depending on
  // the (not-yet-built) AddressChangeEvent model.
  payloadEncrypted String? @db.Text

  nextRetryAt  DateTime?
  dispatchedAt DateTime?
  confirmedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([connectorKey, status])
  @@index([userId])
  @@index([status, nextRetryAt])
  @@index([consentId])
}

// ==================== WORKSPACES (Family/Pro, flag-gated) ====================
// The new isolation root. Every User owns at least one Workspace (backfilled by
// the migration script); Family/Pro share one with extra members. Enum-like
// fields use String @db.VarChar to match the existing schema convention.
// Inert until WORKSPACE_MODEL_ENABLED — domain workspaceId columns are nullable
// and nothing reads them until the dual-read window opens.

model Workspace {
  id          String @id @default(cuid()) @db.VarChar(30)
  ownerUserId String @db.VarChar(30)
  owner       User   @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)

  name String @db.VarChar(120) // display name; plan drives the UI label (My Move/Household/Workspace)

  // Faz 3 ownership transfer skeleton — unset in MVP.
  transferRequestedToUserId String?   @db.VarChar(30)
  transferRequestedAt       DateTime?

  // Soft delete + 7-day grace; hard-delete cron clears expired rows.
  deletedAt          DateTime?
  deletionGraceUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     WorkspaceMember[]
  invitations WorkspaceInvitation[]
  addresses   Address[]
  services    Service[]
  movingPlans MovingPlan[]
  budgets     Budget[]

  @@index([ownerUserId])
  @@index([deletedAt])
  @@index([createdAt])
}

model WorkspaceMember {
  id          String    @id @default(cuid()) @db.VarChar(30)
  workspaceId String    @db.VarChar(30)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String    @db.VarChar(30)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  role   String @default("MEMBER") @db.VarChar(20) // OWNER|ADMIN|MEMBER|CHILD|VIEW_ONLY
  status String @default("ACTIVE") @db.VarChar(20) // ACTIVE|SUSPENDED|OVERFLOW

  // Member consent for owner/admin-initiated "managed sync": pushing an address
  // change to THIS member's connected partners on their behalf (using their own
  // server-held tokens). null = unset → defaults to true for CHILD
  // (guardian-managed), false otherwise. Resolve via resolveManagedSyncEnabled.
  managedSyncEnabled Boolean?

  // Optional guardian link for CHILD (UI hint only; permission is role-based).
  parentMemberId String?           @db.VarChar(30)
  parentMember   WorkspaceMember?  @relation("ChildParent", fields: [parentMemberId], references: [id], onDelete: SetNull)
  childMembers   WorkspaceMember[] @relation("ChildParent")

  invitedByUserId String?   @db.VarChar(30)
  invitationId    String?   @db.VarChar(30)
  joinedAt        DateTime  @default(now())
  lastActiveAt    DateTime?
  suspendedAt     DateTime?
  suspendedReason String?   @db.VarChar(255)
  overflowSince   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId, role])
  @@index([userId])
  @@index([status])
}

model WorkspaceInvitation {
  id          String    @id @default(cuid()) @db.VarChar(30)
  workspaceId String    @db.VarChar(30)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  invitedEmail    String @db.VarChar(191) // lowercased + trimmed
  role            String @default("MEMBER") @db.VarChar(20)
  invitedByUserId String @db.VarChar(30)

  tokenHash  String @unique @db.VarChar(64) // sha256(token); plaintext only in the email
  tokenLast4 String @db.VarChar(8)

  status           String    @default("PENDING") @db.VarChar(20) // PENDING|ACCEPTED|REVOKED|EXPIRED
  expiresAt        DateTime
  acceptedAt       DateTime?
  acceptedByUserId String?   @db.VarChar(30)
  revokedAt        DateTime?
  revokedByUserId  String?   @db.VarChar(30)

  locale String? @db.VarChar(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, invitedEmail, expiresAt])
  @@index([workspaceId, status])
  @@index([invitedEmail, status])
  @@index([expiresAt])
}

// Step-up auth proof for sensitive workspace actions (event create, member
// remove, ownership change). Short-lived; plain user/workspace refs by design.
model WorkspaceAuthChallenge {
  id           String    @id @default(cuid()) @db.VarChar(30)
  userId       String    @db.VarChar(30)
  workspaceId  String    @db.VarChar(30)
  method       String    @db.VarChar(20) // PASSWORD|TOTP|SMS|EMAIL_OTP
  tokenHash    String    @db.VarChar(64)
  challengeFor String    @db.VarChar(40) // ADDRESS_CHANGE_EVENT|MEMBER_REMOVE|ROLE_OWNER_CHANGE|WORKSPACE_DELETE
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId, expiresAt])
  @@index([workspaceId])
}
