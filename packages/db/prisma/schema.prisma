generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== USER & AUTH ====================

model User {
  id        String  @id @default(cuid()) @db.VarChar(30)
  email     String  @unique @db.VarChar(191)
  firstName String? @db.VarChar(100)
  lastName  String? @db.VarChar(100)
  imageUrl  String? @db.VarChar(500)

  // Password auth (null for pure-OAuth accounts)
  passwordHash    String?   @db.VarChar(255)
  emailVerifiedAt DateTime?

  // MFA (TOTP, same pattern as AdminUser)
  mfaEnabled     Boolean @default(false)
  mfaSecret      String? @db.Text // encrypted with FIELD_ENCRYPTION_KEY
  mfaBackupCodes String? @db.Text // JSON array of bcrypt hashes

  // OAuth linkage (one row per user; second provider goes into OAuthAccount)
  oauthAccounts OAuthAccount[]

  // UI preferences (dashboard widget visibility + order, etc.)
  dashboardWidgetPrefs Json?

  // Hide the Budget / Service Costs surface for users who don't track
  // monthly spend. Default true so existing users keep the current view;
  // new users' onboarding flow can flip this off if they opt out.
  showBudget Boolean @default(true)

  // Preferred UI locale. When set, it wins over the `NEXT_LOCALE`
  // cookie and the `Accept-Language` header so the preference follows
  // the user across devices. Null until the user picks a language
  // explicitly — initial visits auto-detect from their browser. See
  // apps/web/src/app/api/user/locale/route.ts.
  preferredLocale String? @db.VarChar(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription            Subscription?
  profile                 Profile?
  addresses               Address[]
  services                Service[]
  budgets                 Budget[]
  movingPlans             MovingPlan[]
  moveTasks               MoveTask[]
  customProviders         UserCustomProvider[]
  loginSessions           UserLoginSession[]
  mobileOAuthCodes        MobileOAuthCode[]
  sessions                UserSession[]
  events                  UserEvent[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  supportTickets          SupportTicket[]
  pushDevices             PushDevice[]
  dataConsents            DataConsent[]
  acquisitionRedemptions  AcquisitionRedemption[]
  partnerConsents         PartnerConsent[]
  connectorDispatches     ConnectorDispatch[]
  ownedWorkspaces         Workspace[]             @relation("WorkspaceOwner")
  workspaceMemberships    WorkspaceMember[]

  // Soft-delete. Populated by admin UI "delete" action; hard-delete runs
  // from cron/data-retention after the undo window. Queries must filter
  // deletedAt: null unless explicitly including deleted records.
  deletedAt DateTime?

  @@index([email])
  @@index([deletedAt])
}

model PushDevice {
  id         String   @id @default(cuid()) @db.VarChar(30)
  userId     String   @db.VarChar(30)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique @db.VarChar(255)
  platform   String   @db.VarChar(10) // "ios" | "android"
  deviceName String?  @db.VarChar(100)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
}

// ==================== AUTH: OAUTH / SESSION / TOKENS ====================

model OAuthAccount {
  id     String @id @default(cuid()) @db.VarChar(30)
  userId String @db.VarChar(30)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider   String @db.VarChar(20) // "google" | "apple"
  providerId String @db.VarChar(255) // sub claim from ID token

  createdAt DateTime @default(now())

  @@unique([provider, providerId])
  @@index([userId])
}

model MobileOAuthCode {
  id            String    @id @default(cuid()) @db.VarChar(30)
  userId        String    @db.VarChar(30)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash      String    @unique @db.VarChar(64)
  provider      String    @db.VarChar(20)
  redirectUri   String    @db.VarChar(500)
  // PKCE code_challenge (base64url(SHA-256(verifier))). When set, the
  // mobile client must present a matching code_verifier at the
  // /api/mobile/auth/exchange step. NULL preserves backwards compat
  // with mobile builds that pre-date P0-6 — they exchange without PKCE
  // and continue to work until those builds age out.
  codeChallenge String?   @db.VarChar(128)
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model UserLoginSession {
  id           String   @id @default(cuid()) @db.VarChar(30)
  userId       String   @db.VarChar(30)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String   @unique @db.VarChar(64)
  ipAddress    String?  @db.VarChar(45)
  userAgent    String?  @db.VarChar(500)
  browser      String?  @db.VarChar(50)
  os           String?  @db.VarChar(50)
  deviceType   String?  @db.VarChar(30)
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  lastActivity DateTime @default(now())
  createdAt    DateTime @default(now())

  // Impersonation — populated when a SUPER_ADMIN is acting as the user.
  // Sessions with this set are capped at 15 minutes, show a persistent
  // banner in the app, and write an AdminAuditLog row per request.
  impersonatedByAdminId String? @db.VarChar(30)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([impersonatedByAdminId])
}

model OAuthState {
  id          String    @id @default(cuid()) @db.VarChar(30)
  provider    String    @db.VarChar(20)
  stateHash   String    @unique @db.VarChar(64)
  nonceHash   String    @db.VarChar(64)
  redirectUri String?   @db.VarChar(500)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([provider, expiresAt])
  @@index([provider, consumedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid()) @db.VarChar(30)
  userId    String    @db.VarChar(30)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @db.VarChar(64)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ==================== DATA CONSENT (GDPR / CCPA) ====================
//
// Captures the user's explicit opt-in/opt-out per data-processing category.
// Categories map to concrete behaviors:
//   ANALYTICS   → Sentry, PostHog, UserSession tracking
//   MARKETING   → Resend marketing emails (weekly digest, upsells)
//   SENSITIVE   → storing Profile.isImmigrant / hasDisability / isMilitary
//   FUNCTIONAL  → essential cookies, always implicitly granted
// Revocation is non-destructive: we keep a history so we can prove the
// lifecycle in audit. The *current* effective consent is the newest row
// per (userId, category).
model DataConsent {
  id     String @id @default(cuid()) @db.VarChar(30)
  userId String @db.VarChar(30)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  category  String  @db.VarChar(20) // ANALYTICS | MARKETING | SENSITIVE | FUNCTIONAL
  granted   Boolean
  version   String  @db.VarChar(20) // consent-text version, e.g. "2026-04"
  ipAddress String? @db.VarChar(45)
  userAgent String? @db.VarChar(500)

  createdAt DateTime @default(now())

  @@index([userId, category, createdAt])
  @@index([category])
}

model EmailVerificationToken {
  id         String    @id @default(cuid()) @db.VarChar(30)
  userId     String    @db.VarChar(30)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      String    @db.VarChar(191)
  tokenHash  String    @unique @db.VarChar(64)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Subscription {
  id     String @id @default(cuid()) @db.VarChar(30)
  userId String @unique @db.VarChar(30)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan     String  @default("FREE_TRIAL") @db.VarChar(30)
  status   String  @default("FREE_ACCESS") @db.VarChar(30)
  provider String  @default("TRIAL") @db.VarChar(30)
  platform String? @db.VarChar(20)

  stripeCustomerId                  String?                 @unique @db.VarChar(191)
  stripeSubscriptionId              String?                 @unique @db.VarChar(191)
  stripeSubscriptionScheduleId      String?                 @db.VarChar(191)
  stripePriceId                     String?                 @db.VarChar(191)
  stripeCurrentPeriodEnd            DateTime?
  billingProductId                  String?                 @db.VarChar(191)
  originalTransactionId             String?                 @unique @db.VarChar(191)
  latestTransactionId               String?                 @db.VarChar(191)
  purchaseToken                     String?                 @db.Text
  purchaseTokenHash                 String?                 @unique @db.VarChar(64)
  appStoreEnvironment               String?                 @db.VarChar(30)
  currentPeriodEndsAt               DateTime?
  gracePeriodEndsAt                 DateTime?
  lastValidatedAt                   DateTime?
  lastSyncedAt                      DateTime?
  accessType                        String?                 @db.VarChar(30)
  billingInterval                   String?                 @db.VarChar(20)
  pendingBillingInterval            String?                 @db.VarChar(20)
  pendingBillingIntervalEffectiveAt DateTime?
  freeAccessEndsAt                  DateTime?
  cancelAtPeriodEnd                 Boolean                 @default(false)
  firstChargeAt                     DateTime?
  firstChargeAmount                 Float?
  autoRenew                         Boolean?
  campaignId                        String?                 @db.VarChar(30)
  campaignCode                      String?                 @db.VarChar(80)
  campaignSnapshot                  String?                 @db.Text
  checkoutConsentSnapshot           String?                 @db.Text
  termsVersion                      String?                 @db.VarChar(30)
  subscriptionPolicyVersion         String?                 @db.VarChar(30)
  refundPolicyVersion               String?                 @db.VarChar(30)
  acquisitionCampaign               AcquisitionCampaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  acquisitionRedemptions            AcquisitionRedemption[]

  trialEndsAt         DateTime?
  canceledAt          DateTime?
  // Reason captured by the cancel-survey modal at the moment the user
  // cancels renewal or a trial. Category is a fixed enum-ish slug
  // (`too_expensive`, `not_using`, `missing_feature`, ...); comment is the
  // optional free-text follow-up. Both nullable; surveys are skippable.
  cancelReason        String?   @db.VarChar(40)
  cancelReasonComment String?   @db.VarChar(500)

  premiumUntil     DateTime?
  premiumGrantedBy String?   @db.VarChar(30)
  premiumGrantedAt DateTime?
  premiumNote      String?   @db.VarChar(500)

  // Stripe delivers webhook events at-least-once and out-of-order. This is the
  // `event.created` timestamp of the most recent Stripe event we applied; an
  // incoming event older than this is stale (a late retry of a superseded
  // state) and must be skipped so it can't overwrite newer billing state.
  lastStripeEventAt DateTime?

  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionScheduleId])
  @@index([provider, status])
  @@index([platform, provider])
  @@index([billingProductId])
  @@index([currentPeriodEndsAt])
  @@index([pendingBillingIntervalEffectiveAt])
  @@index([accessType, status])
  @@index([campaignId])
  @@index([cancelReason])
}

model AcquisitionCampaign {
  id     String @id @default(cuid()) @db.VarChar(30)
  name   String @db.VarChar(120)
  code   String @unique @db.VarChar(80)
  status String @default("DRAFT") @db.VarChar(20)

  accessType            String  @db.VarChar(30)
  plan                  String  @default("INDIVIDUAL") @db.VarChar(30)
  billingInterval       String? @db.VarChar(20)
  trialDays             Int?
  freeAccessDays        Int?
  stripePriceId         String? @db.VarChar(191)
  displayPriceLabel     String? @db.VarChar(80)
  requiresPaymentMethod Boolean @default(false)
  autoRenew             Boolean @default(false)
  newUsersOnly          Boolean @default(true)

  startsAt        DateTime?
  endsAt          DateTime?
  maxRedemptions  Int?
  redemptionCount Int       @default(0)

  internalNotes          String? @db.Text
  publicHeadline         String  @db.VarChar(200)
  publicSubheadline      String? @db.VarChar(500)
  checkoutDisclosureCopy String? @db.Text

  createdByAdminId String?    @db.VarChar(30)
  createdByAdmin   AdminUser? @relation("AcquisitionCampaignsCreated", fields: [createdByAdminId], references: [id], onDelete: SetNull)

  subscriptions Subscription[]
  redemptions   AcquisitionRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([accessType, plan])
  @@index([startsAt, endsAt])
  @@index([createdByAdminId])
}

model AcquisitionRedemption {
  id String @id @default(cuid()) @db.VarChar(30)

  campaignId String?              @db.VarChar(30)
  campaign   AcquisitionCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  userId String @db.VarChar(30)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subscriptionId String?       @db.VarChar(30)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  accessType String @db.VarChar(30)
  status     String @default("REDEEMED") @db.VarChar(30)
  snapshot   String @db.Text

  consentAcceptedAt          DateTime?
  consentIpHash              String?   @db.VarChar(64)
  consentUserAgentHash       String?   @db.VarChar(64)
  termsVersion               String?   @db.VarChar(30)
  subscriptionPolicyVersion  String?   @db.VarChar(30)
  refundPolicyVersion        String?   @db.VarChar(30)
  checkoutDisclosureTextHash String?   @db.VarChar(64)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
  @@index([userId])
  @@index([subscriptionId])
  @@index([accessType, status])
}

// ==================== PROFILE ====================

model Profile {
  id     String @id @default(cuid()) @db.VarChar(30)
  userId String @unique @db.VarChar(30)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ageRange     String? @db.VarChar(30)
  familyStatus String? @db.VarChar(30)

  hasChildren   Boolean @default(false)
  childrenCount Int     @default(0)
  hasSenior     Boolean @default(false)
  hasDisability Boolean @default(false)
  hasPets       Boolean @default(false)
  petTypes      String  @default("[]") @db.VarChar(500)

  carCount      Int     @default(0)
  hasMotorcycle Boolean @default(false)
  hasBoatRV     Boolean @default(false)
  needsStorage  Boolean @default(false)

  moveType          String? @db.VarChar(20)
  isBusinessOwner   Boolean @default(false)
  businessType      String? @db.VarChar(30)
  isImmigrant       Boolean @default(false)
  immigrationStatus String? @db.VarChar(30)
  isMilitary        Boolean @default(false)

  preferredLanguage String @default("en") @db.VarChar(10)
  timezone          String @default("America/New_York") @db.VarChar(50)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ==================== ADDRESSES ====================

model Address {
  id     String @id @default(cuid()) @db.VarChar(30)
  userId String @db.VarChar(30)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Workspace isolation axis (Family/Pro). Nullable in Phase 1; backfilled by
  // the migration script, then promoted to NOT NULL in Phase 3. `userId` stays
  // as the record-owner. Inert until WORKSPACE_MODEL_ENABLED.
  workspaceId String?    @db.VarChar(30)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  type     String  @db.VarChar(20)
  nickname String? @db.VarChar(50)

  street  String  @db.VarChar(200)
  street2 String? @db.VarChar(200)
  city    String  @db.VarChar(100)
  state   String  @db.VarChar(2)
  zip     String  @db.VarChar(10)
  country String  @default("USA") @db.VarChar(10)

  isPrimary Boolean @default(false)
  ownership String  @db.VarChar(20)

  startDate DateTime
  endDate   DateTime?

  latitude         Float?
  longitude        Float?
  placeId          String? @db.VarChar(191)
  formattedAddress String? @db.Text

  services             Service[]
  budgets              Budget[]
  movingPlansFrom      MovingPlan[] @relation("FromAddress")
  movingPlansTo        MovingPlan[] @relation("ToAddress")
  moveTasksOrigin      MoveTask[]   @relation("MoveTaskOriginAddress")
  moveTasksDestination MoveTask[]   @relation("MoveTaskDestinationAddress")

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([workspaceId])
  @@index([zip])
  @@index([state])
  @@index([userId, zip])
  @@index([deletedAt])
}

// ==================== SERVICES ====================

model Service {
  id     String @id @default(cuid()) @db.VarChar(30)
  userId String @db.VarChar(30)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String?    @db.VarChar(30) // workspace isolation axis (Family/Pro), nullable Phase 1
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  addressId String  @db.VarChar(30)
  address   Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  providerId String?          @db.VarChar(30)
  provider   ServiceProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  customProviderId String?             @db.VarChar(30)
  customProvider   UserCustomProvider? @relation(fields: [customProviderId], references: [id], onDelete: SetNull)

  category     String  @db.VarChar(50)
  subCategory  String? @db.VarChar(50)
  providerName String  @db.VarChar(200)

  accountNumber String? @db.Text
  username      String? @db.Text

  website String? @db.VarChar(500)
  phone   String? @db.Text
  email   String? @db.Text

  monthlyCost     Float?
  billingDay      Int?
  billingCycle    String?   @db.VarChar(20)
  autoRenewal     Boolean   @default(false)
  contractEndDate DateTime?

  notes String? @db.Text

  isActive      Boolean   @default(true)
  activatedAt   DateTime?
  deactivatedAt DateTime?

  migrationAction   String? @db.VarChar(20)
  previousServiceId String? @db.VarChar(30)

  personalRating Int?
  personalReview String? @db.Text

  reminders Reminder[]
  moveTasks MoveTask[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([workspaceId])
  @@index([addressId])
  @@index([category])
  @@index([providerName])
  @@index([providerId])
  @@index([customProviderId])
  @@index([userId, isActive])
  @@index([userId, category])
  @@index([userId, addressId, isActive])
  @@index([deletedAt])
}

// ==================== MOVING PLAN ====================

model MovingPlan {
  id     String @id @default(cuid()) @db.VarChar(30)
  userId String @db.VarChar(30)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String?    @db.VarChar(30) // workspace isolation axis (Family/Pro), nullable Phase 1
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Explicit ON DELETE RESTRICT — the SQL FK already behaves this way
  // (Prisma's MySQL default for required relations) but we name it here
  // so future schema sync can't silently drift to Cascade and quietly
  // wipe move history when an Address is hard-deleted. Soft-delete on
  // Address remains the canonical user-facing path.
  fromAddressId String  @db.VarChar(30)
  fromAddress   Address @relation("FromAddress", fields: [fromAddressId], references: [id], onDelete: Restrict)

  toAddressId String  @db.VarChar(30)
  toAddress   Address @relation("ToAddress", fields: [toAddressId], references: [id], onDelete: Restrict)

  moveDate          DateTime
  isTemporary       Boolean  @default(false)
  estimatedDuration Int?

  status String @default("PLANNING") @db.VarChar(20)

  deletedAt DateTime?

  version Int @default(1)

  moveTasks MoveTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([workspaceId])
  @@index([fromAddressId])
  @@index([toAddressId])
  @@index([moveDate])
  @@index([deletedAt])
}

// ==================== BUDGET ====================

model Budget {
  id     String @id @default(cuid()) @db.VarChar(30)
  userId String @db.VarChar(30)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String?    @db.VarChar(30) // workspace isolation axis (Family/Pro), nullable Phase 1
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  addressId String?  @db.VarChar(30)
  address   Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)
  scopeKey  String   @db.VarChar(64)

  month DateTime
  year  Int

  plannedIncome   Float?
  actualIncome    Float?
  plannedExpenses Float?
  actualExpenses  Float

  categoryBreakdown String? @db.Text

  savingsRate Float?
  notes       String? @db.Text

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, scopeKey, month])
  @@index([userId])
  @@index([workspaceId])
  @@index([scopeKey])
  @@index([month])
  @@index([deletedAt])
}

// ==================== REMINDERS ====================

model Reminder {
  id String @id @default(cuid()) @db.VarChar(30)

  serviceId String?  @db.VarChar(30)
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  type    String  @db.VarChar(30)
  title   String  @db.VarChar(200)
  message String? @db.Text

  remindAt DateTime
  sent     Boolean   @default(false)
  sentAt   DateTime?

  isRecurring    Boolean @default(false)
  recurrenceRule String? @db.VarChar(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([remindAt, sent])
  @@index([serviceId])
}

// ==================== STATE RULES ====================

model StateRule {
  id String @id @default(cuid()) @db.VarChar(30)

  stateCode String @unique @db.VarChar(5)
  stateName String @db.VarChar(50)

  dmvRules          String? @db.Text
  voterRegistration String? @db.Text
  utilityInfo       String? @db.Text
  taxInfo           String? @db.Text
  insuranceRules    String? @db.Text
  commonProviders   String? @db.Text

  updatedAt DateTime @updatedAt

  @@index([stateCode])
}

model ServiceProvider {
  id String @id @default(cuid()) @db.VarChar(30)

  name        String  @db.VarChar(200)
  slug        String  @unique @db.VarChar(191)
  category    String  @db.VarChar(50)
  subCategory String? @db.VarChar(50)
  description String? @db.Text

  website String? @db.VarChar(500)
  phone   String? @db.VarChar(20)
  logoUrl String? @db.VarChar(500)

  scope    String @default("FEDERAL") @db.VarChar(20)
  states   String @default("[]") @db.VarChar(2000)
  zipCodes String @default("[]") @db.VarChar(2000)

  tags String @default("[]") @db.VarChar(2000)

  popularityScore Int     @default(0)
  isActive        Boolean @default(true)
  displayOrder    Int     @default(0)

  userCount     Int     @default(0)
  lastUpdatedBy String? @db.VarChar(30)

  services              Service[]
  coverages             ServiceProviderCoverage[]
  linkedCustomProviders UserCustomProvider[]      @relation("LinkedCustomProviders")
  moveTasks             MoveTask[]                @relation("MoveTaskProvider")
  destinationMoveTasks  MoveTask[]                @relation("MoveTaskDestinationProvider")
  governanceIssues      ProviderGovernanceIssue[]
  logoCandidates        ProviderLogoCandidate[]

  deletedAt DateTime?

  // Optimistic locking. Every update must match the version the caller read
  // and increment it. See packages/db/src/optimistic-locking.ts.
  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([scope])
  @@index([slug])
  @@index([deletedAt])
}

model ProviderLogoCandidate {
  id String @id @default(cuid()) @db.VarChar(30)

  providerId String          @db.VarChar(30)
  provider   ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  source      String  @db.VarChar(30)
  sourceUrl   String? @db.VarChar(1000)
  publicUrl   String  @db.VarChar(500)
