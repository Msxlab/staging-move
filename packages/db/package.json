{
  "name": "@locateflow/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "push": "prisma db push",
    "seed": "tsx prisma/seed-master.ts",
    "seed:providers": "tsx prisma/seed-providers.ts",
    "seed:all-states": "tsx prisma/seed-providers-all-states.ts",
    "seed:expanded": "tsx prisma/seed-providers-expanded.ts",
    "seed:government": "tsx prisma/seed-providers-government.ts",
    "seed:admin": "tsx prisma/seed-admin.ts",
    "seed:blog": "tsx prisma/seed-blog.ts",
    "seed:master": "tsx prisma/seed-master.ts",
    "seed:all": "tsx prisma/seed-master.ts && tsx prisma/seed-admin.ts",
    "studio": "prisma studio"
  },
  "dependencies": {
    "@locateflow/shared": "workspace:*",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.6.0",
    "dotenv": "^16.4.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0"
  }
}
